---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_LANG } from '../consts';

const posts = (await getCollection('post')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Group by year then month
type PostItem = typeof posts[number];
const grouped: Record<number, Record<number, PostItem[]>> = {};
for (const post of posts) {
	const y = post.data.pubDate.getFullYear();
	const m = post.data.pubDate.getMonth() + 1;
	if (!grouped[y]) grouped[y] = {};
	if (!grouped[y][m]) grouped[y][m] = [];
	grouped[y][m].push(post);
}
const years = Object.keys(grouped).map(Number).sort((a, b) => b - a);
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={`归档 - ${SITE_TITLE}`} description="文章归档" />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header animate-in">
				<h1>归档</h1>
				<p>共 {posts.length} 篇文章</p>
			</div>

			{years.map((year, yi) => (
				<section class="archive-year animate-in" style={`animation-delay: ${0.1 + yi * 0.08}s`}>
					<h2 class="year-title">{year}</h2>
					{Object.keys(grouped[year]).map(Number).sort((a, b) => b - a).map((month) => (
						<div class="archive-month">
							<h3 class="month-title">{month} 月</h3>
							<ul class="archive-list">
								{grouped[year][month].map((post) => (
									<li>
										<a href={`${import.meta.env.BASE_URL}post/${post.id}/`} class="archive-link">
											<span class="archive-date"><FormattedDate date={post.data.pubDate} /></span>
											<span class="archive-title">{post.data.title}</span>
										</a>
									</li>
								))}
							</ul>
						</div>
					))}
				</section>
			))}
		</main>
		<Footer />

		<style>
			main {
				max-width: 740px;
				width: 100%;
				padding: 2em 1.5em 3em;
			}
			.page-header {
				margin-bottom: 2.5em;
				display: flex;
				align-items: baseline;
				gap: 0.8em;
			}
			.page-header h1 {
				font-size: 1.6em;
				margin: 0;
			}
			.page-header p {
				font-size: 0.88em;
				color: rgb(var(--stone));
				margin: 0;
			}
			.archive-year {
				margin-bottom: 2.5em;
			}
			.year-title {
				font-size: 1.3em;
				color: rgb(var(--ink));
				margin: 0 0 1em;
				padding-bottom: 0.5em;
				border-bottom: 2px solid rgb(var(--sand-dark));
			}
			.archive-month {
				margin-bottom: 1.5em;
			}
			.month-title {
				font-size: 0.92em;
				color: rgb(var(--stone));
				margin: 0 0 0.6em;
				font-weight: 600;
			}
			.archive-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.archive-list li {
				margin-bottom: 0.3em;
			}
			.archive-link {
				display: flex;
				align-items: baseline;
				gap: 1em;
				padding: 0.5em 0.8em;
				border-radius: 6px;
				text-decoration: none;
				transition: all var(--transition);
			}
			.archive-link:hover {
				background: var(--jade-glow);
			}
			.archive-date {
				font-size: 0.8em;
				color: rgb(var(--stone));
				white-space: nowrap;
				flex-shrink: 0;
				min-width: 7em;
			}
			.archive-title {
				font-size: 0.95em;
				color: rgb(var(--ink-light));
				transition: color var(--transition);
			}
			.archive-link:hover .archive-title {
				color: var(--jade);
			}
			@media (max-width: 720px) {
				main {
					padding: 1.5em 1.25em 2em;
				}
				.archive-link {
					flex-direction: column;
					gap: 0.2em;
				}
			}
		</style>
	</body>
</html>
