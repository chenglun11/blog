---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_LANG, HERO } from '../consts';

const posts = (await getCollection('post')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 4);
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-inner">
				<p class="hero-greeting">{HERO.greeting}</p>
				<h1 class="hero-title">{HERO.title}</h1>
				<p class="hero-desc">
					{HERO.description}
				</p>
				<a href={`${import.meta.env.BASE_URL}post/`} class="hero-cta">
					{HERO.ctaText}
					<svg width="16" height="16" viewBox="0 0 16 16" fill="none">
						<path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</section>

		<!-- Recent Posts -->
		<main>
			<section class="recent-section">
				<div class="section-header">
					<h2>最近文章</h2>
					<a href={`${import.meta.env.BASE_URL}post/`} class="view-all">
						查看全部
						<svg width="14" height="14" viewBox="0 0 16 16" fill="none">
							<path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>
				</div>
				<div class="posts-list">
					{recentPosts.map((post, i) => (
						<a href={`${import.meta.env.BASE_URL}post/${post.id}/`} class="post-card" style={`animation-delay: ${i * 0.08}s`}>
							{post.data.heroImage && (
								<div class="post-image">
									<Image width={600} height={340} src={post.data.heroImage} alt="" />
								</div>
							)}
							<div class="post-content">
								<time class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</time>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-desc">{post.data.description}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		</main>

		<Footer />

		<style>
			/* Hero */
			.hero {
				padding: 5em 1.5em 4em;
				text-align: center;
				border-bottom: 1px solid rgb(var(--sand-dark));
			}
			.hero-inner {
				max-width: 640px;
				margin: 0 auto;
				animation: fadeUp 0.7s var(--ease-out) both;
			}
			.hero-greeting {
				font-size: 0.92em;
				color: var(--accent);
				letter-spacing: 0.06em;
				margin-bottom: 0.6em;
				font-weight: 500;
			}
			.hero-title {
				font-size: 2.8em;
				letter-spacing: -0.02em;
				margin-bottom: 0.5em;
				color: rgb(var(--ink));
				line-height: 1.2;
			}
			.hero-desc {
				font-size: 1.05em;
				color: rgb(var(--stone));
				line-height: 1.8;
				margin-bottom: 2em;
			}
			.hero-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: 0.7em 1.6em;
				background: var(--accent);
				color: white;
				border-radius: 8px;
				font-size: 0.92em;
				font-weight: 600;
				letter-spacing: 0.02em;
				transition: all var(--transition);
				box-shadow: 0 2px 8px var(--accent-glow);
			}
			.hero-cta:hover {
				background: var(--accent-dark);
				color: white;
				transform: translateY(-1px);
				box-shadow: 0 4px 16px var(--accent-glow);
			}
			.hero-cta svg {
				transition: transform var(--transition);
			}
			.hero-cta:hover svg {
				transform: translateX(2px);
			}
			.hide-mobile {
				display: inline;
			}

			/* Main */
			main {
				max-width: 880px;
				width: 100%;
				padding: 3em 1.5em;
			}

			/* Section Header */
			.section-header {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				margin-bottom: 2em;
				animation: fadeUp 0.6s var(--ease-out) 0.1s both;
			}
			.section-header h2 {
				font-size: 1.3em;
				margin: 0;
				color: rgb(var(--ink));
			}
			.view-all {
				display: inline-flex;
				align-items: center;
				gap: 0.3em;
				font-size: 0.88em;
				color: var(--accent);
				font-weight: 500;
				transition: gap var(--transition);
			}
			.view-all:hover {
				gap: 0.5em;
				color: var(--accent-dark);
			}

			/* Posts */
			.posts-list {
				display: flex;
				flex-direction: column;
				gap: 1px;
				background: rgb(var(--sand-dark));
				border-radius: var(--radius-lg);
				overflow: hidden;
				box-shadow: var(--box-shadow);
			}
			.post-card {
				display: flex;
				gap: 1.5em;
				padding: 1.5em;
				background: rgb(var(--cream));
				text-decoration: none;
				transition: background var(--transition);
				animation: fadeUp 0.6s var(--ease-out) both;
			}
			.post-card:hover {
				background: rgb(var(--sand));
			}
			.post-image {
				flex-shrink: 0;
				width: 180px;
				height: 120px;
				overflow: hidden;
				border-radius: var(--radius);
			}
			.post-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: var(--radius);
				transition: transform 0.5s var(--ease);
			}
			.post-card:hover .post-image img {
				transform: scale(1.04);
			}
			.post-content {
				display: flex;
				flex-direction: column;
				justify-content: center;
				min-width: 0;
			}
			.post-date {
				font-size: 0.82em;
				color: rgb(var(--stone));
				margin-bottom: 0.4em;
				letter-spacing: 0.02em;
			}
			.post-title {
				font-size: 1.1em;
				color: rgb(var(--ink));
				margin: 0 0 0.4em;
				line-height: 1.4;
				transition: color var(--transition);
			}
			.post-card:hover .post-title {
				color: var(--accent);
			}
			.post-desc {
				font-size: 0.88em;
				color: rgb(var(--stone));
				margin: 0;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 3.5em 1.25em 3em;
				}
				.hero-title {
					font-size: 2em;
				}
				.hero-desc {
					font-size: 0.95em;
				}
				.hide-mobile {
					display: none;
				}
				main {
					padding: 2em 1.25em;
				}
				.post-card {
					flex-direction: column;
					gap: 1em;
					padding: 1.25em;
				}
				.post-image {
					width: 100%;
					height: 180px;
				}
			}
		</style>
	</body>
</html>
