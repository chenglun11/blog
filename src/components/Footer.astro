---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-divider"></div>
		<div class="footer-content">
			<div class="footer-left">
				<p class="copyright">&copy; {today.getFullYear()} 我的技术博客</p>
				<p class="tagline">记录学习、分享思考</p>
			</div>
			<div class="footer-right">
				<a href={`${import.meta.env.BASE_URL}rss.xml`} class="footer-link">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M4 11a9 9 0 0 1 9 9"/>
						<path d="M4 4a16 16 0 0 1 16 16"/>
						<circle cx="5" cy="19" r="1"/>
					</svg>
					RSS
				</a>
				<a href="https://github.com/chenglun11" target="_blank" class="footer-link">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
					GitHub
				</a>
			</div>
		</div>
		<p class="footer-note">使用 <a href="https://astro.build/" target="_blank">Astro</a> 构建</p>
	</div>
</footer>
<style>
	footer {
		padding: 0 1.5em 3em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
	}
	.footer-divider {
		height: 1px;
		background: linear-gradient(
			to right,
			transparent,
			rgb(var(--sand-dark)) 20%,
			rgb(var(--sand-dark)) 80%,
			transparent
		);
		margin-bottom: 2.5em;
	}
	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}
	.footer-left p {
		margin: 0;
	}
	.copyright {
		font-size: 0.88em;
		color: rgb(var(--ink-light));
		font-weight: 500;
	}
	.tagline {
		font-size: 0.8em;
		color: rgb(var(--stone));
		margin-top: 0.3em;
	}
	.footer-right {
		display: flex;
		gap: 0.6em;
	}
	.footer-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.84em;
		color: rgb(var(--stone));
		text-decoration: none;
		padding: 0.45em 0.9em;
		border: 1px solid rgb(var(--sand-dark));
		border-radius: 6px;
		transition: all var(--transition);
		letter-spacing: 0.01em;
	}
	.footer-link:hover {
		color: var(--jade);
		border-color: var(--jade);
		background: var(--jade-glow);
	}
	.footer-note {
		margin-top: 2em;
		font-size: 0.78em;
		color: rgb(var(--stone));
		opacity: 0.5;
		text-align: center;
	}
	.footer-note a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.footer-note a:hover {
		color: var(--jade);
	}
	@media (max-width: 720px) {
		footer {
			padding: 0 1.25em 2.5em;
		}
		.footer-content {
			flex-direction: column;
			align-items: center;
			gap: 1.5em;
			text-align: center;
		}
	}
</style>
