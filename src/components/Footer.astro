	zhihu: {
		label: '知乎',
		svg: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M5.721 0C2.251 0 0 2.25 0 5.719V18.28C0 21.751 2.252 24 5.721 24h12.56C21.751 24 24 21.75 24 18.281V5.72C24 2.249 21.75 0 18.281 0zm1.964 4.078h6.46c.09 0 .164.073.164.164v.921c0 .09-.073.164-.164.164H9.93l-.363 2.06h3.63c.09 0 .163.074.163.164v.922c0 .09-.073.163-.163.163h-3.96l-.584 3.305h4.873c.09 0 .164.073.164.163v.922c0 .09-.074.164-.164.164H7.685a.164.164 0 0 1-.163-.164v-.922c0-.09.073-.163.163-.163h.328l.584-3.305H7.03a.164.164 0 0 1-.164-.163v-.922c0-.09.074-.164.164-.164h1.896l.363-2.06H7.685a.164.164 0 0 1-.163-.164v-.921c0-.091.073-.164.163-.164zm7.45 1.901h2.531c.09 0 .164.073.164.163v10.5c0 .09-.074.164-.164.164h-2.531a.164.164 0 0 1-.164-.164v-10.5c0-.09.074-.163.164-.163z"/></svg>',
	},
};

// 过滤出有值的社交链接
const activeSocials = Object.entries(SOCIAL).filter(([_, url]) => url);
---

<footer>
	<div class="footer-inner">
		<div class="footer-divider"></div>
		<div class="footer-content">
			<div class="footer-left">
				<p class="copyright">{FOOTER.copyright}</p>
				{FOOTER.tagline && <p class="tagline">{FOOTER.tagline}</p>}
				{FOOTER.icp && <a href="https://beian.miit.gov.cn/" target="_blank" class="icp">{FOOTER.icp}</a>}
			</div>
			<div class="footer-right">
				{FEATURES.rss && (
					<a href={`${import.meta.env.BASE_URL}rss.xml`} class="footer-link">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M4 11a9 9 0 0 1 9 9"/>
							<path d="M4 4a16 16 0 0 1 16 16"/>
							<circle cx="5" cy="19" r="1"/>
						</svg>
						RSS
					</a>
				)}
				{activeSocials.map(([key, url]) => {
					const icon = socialIcons[key];
					return icon ? (
						<a href={url} target="_blank" class="footer-link">
							<Fragment set:html={icon.svg} />
							{icon.label}
						</a>
					) : null;
				})}
			</div>
		</div>
		<p class="footer-note">
			{FOOTER.poweredBy && (<>使用 <a href="https://astro.build/" target="_blank">Astro</a> 构建</>)}
			{FOOTER.links && FOOTER.links.map((link) => (
				<>{FOOTER.poweredBy || FOOTER.links!.indexOf(link) > 0 ? ' · ' : ''}<a href={link.href.startsWith('http') ? link.href : `${import.meta.env.BASE_URL}${link.href}`} target={link.href.startsWith('http') ? '_blank' : undefined}>{link.text}</a></>
			))}
		</p>
		{FOOTER.customHtml && <div class="footer-custom" set:html={FOOTER.customHtml} />}
	</div>
</footer>
<style>
	footer {
		padding: 0 1.5em 3em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
	}
	.footer-divider {
		height: 1px;
		background: linear-gradient(
			to right,
			transparent,
			rgb(var(--sand-dark)) 20%,
			rgb(var(--sand-dark)) 80%,
			transparent
		);
		margin-bottom: 2.5em;
	}
	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}
	.footer-left p {
		margin: 0;
	}
	.copyright {
		font-size: 0.88em;
		color: rgb(var(--ink-light));
		font-weight: 500;
	}
	.tagline {
		font-size: 0.8em;
		color: rgb(var(--stone));
		margin-top: 0.3em;
	}
	.icp {
		display: block;
		font-size: 0.75em;
		color: rgb(var(--stone));
		text-decoration: none;
		margin-top: 0.4em;
		opacity: 0.6;
	}
	.icp:hover {
		color: var(--accent);
		opacity: 1;
	}
	.footer-right {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
		justify-content: flex-end;
	}
	.footer-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.84em;
		color: rgb(var(--stone));
		text-decoration: none;
		padding: 0.45em 0.9em;
		border: 1px solid rgb(var(--sand-dark));
		border-radius: 6px;
		transition: all var(--transition);
		letter-spacing: 0.01em;
	}
	.footer-link:hover {
		color: var(--accent);
		border-color: var(--accent);
		background: var(--accent-glow);
	}
	.footer-note {
		margin-top: 2em;
		font-size: 0.78em;
		color: rgb(var(--stone));
		opacity: 0.5;
		text-align: center;
	}
	.footer-note a {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	.footer-note a:hover {
		color: var(--accent);
	}
	.footer-custom {
		margin-top: 1em;
		font-size: 0.78em;
		color: rgb(var(--stone));
		opacity: 0.5;
		text-align: center;
	}
	.footer-custom :global(a) {
		color: inherit;
		text-decoration: none;
	}
	.footer-custom :global(a:hover) {
		color: var(--accent);
		opacity: 1;
	}
	.footer-custom :global(img) {
		vertical-align: middle;
		height: 14px;
	}
	@media (max-width: 720px) {
		footer {
			padding: 0 1.25em 2.5em;
		}
		.footer-content {
			flex-direction: column;
			align-items: center;
			gap: 1.5em;
			text-align: center;
		}
		.footer-right {
			justify-content: center;
		}
	}
</style>
