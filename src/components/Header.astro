---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href={`${import.meta.env.BASE_URL}`} class="site-title">
			<span class="title-mark"></span>
			{SITE_TITLE}
		</a>
		<div class="nav-links">
			<HeaderLink href={`${import.meta.env.BASE_URL}`}>首页</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}post`}>文章</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}timeline`}>时间线</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}about`}>关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(252, 251, 249, 0.9);
		backdrop-filter: blur(16px) saturate(1.2);
		-webkit-backdrop-filter: blur(16px) saturate(1.2);
		border-bottom: 1px solid rgba(235, 231, 226, 0.6);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 60px;
	}
	.site-title {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-weight: 700;
		font-size: 1.05em;
		color: rgb(var(--ink));
		text-decoration: none;
		letter-spacing: 0.02em;
		transition: color var(--transition);
	}
	.title-mark {
		display: inline-block;
		width: 6px;
		height: 6px;
		background: var(--jade);
		border-radius: 50%;
		flex-shrink: 0;
	}
	.site-title:hover {
		color: var(--jade);
	}
	.nav-links {
		display: flex;
		gap: 0.15em;
	}
	@media (max-width: 720px) {
		nav {
			padding: 0 1.25em;
		}
	}
</style>
